<Window x:Class="HarryGraph.GraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HarryGraph"
        Title="HarryGraph — Detail" Height="780" Width="1180"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="{StaticResource WindowBg}">
    <!-- A normal resizable window: use the title-bar maximize/restore freely. -->
    <local:GraphPanelControl x:Name="Host" Width="Auto" Height="Auto" Margin="6" />
</Window>
