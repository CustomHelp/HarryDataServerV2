<Window x:Class="HarryGraph.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HarryGraph"
        Title="HarryGraph" Height="820" Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}">
    <DockPanel>
        <!-- ===== Top bar ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBg}" Padding="14,8"
                BorderBrush="{DynamicResource Accent}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Height="32" HorizontalAlignment="Left"
                       Source="pack://application:,,,/HarryShared;component/Assets/CustomHelpLogo.png" />
                <TextBlock Grid.Column="1" Text="{Binding AppName}" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="ThemeToggle" Click="OnThemeToggle" Content="Theme"
                            Padding="8,3" Margin="0,0,12,0" ToolTip="Switch light / dark theme" />
                    <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource TextDimBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Status bar ===== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding ConfigFile, StringFormat=Config: {0}}" /></StatusBarItem>
        </StatusBar>

        <!-- ===== Toolbar ===== -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="8,8,8,0">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Graphs:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" />
                <Button Content="–" Command="{Binding RemovePanelCommand}" Width="32" Margin="0,0,4,0"
                        ToolTip="Remove last graph" />
                <TextBlock Text="{Binding PanelCount}" VerticalAlignment="Center" Margin="2,0" MinWidth="16"
                           TextAlignment="Center" />
                <Button Content="+" Command="{Binding AddPanelCommand}" Width="32" Margin="4,0,16,0"
                        ToolTip="Add a graph (max 6)" />

                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <DatePicker SelectedDate="{Binding FromDate}" Width="120" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <DatePicker SelectedDate="{Binding ToDate}" Width="120" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="Live window (min):" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Width="50" Text="{Binding LiveWindowMinutes}" VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button Content="Refresh all" Command="{Binding RefreshAllCommand}" />
            </WrapPanel>
        </Border>

        <!-- ===== Graph panels ===== -->
        <ScrollViewer x:Name="PanelScroller" VerticalScrollBarVisibility="Auto" Margin="4">
            <ItemsControl ItemsSource="{Binding Panels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:GraphPanelControl />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
