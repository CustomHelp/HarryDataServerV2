<Window x:Class="HarryDataServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:HarryDataServer.Controls"
        Title="HarryDataServer V2" Height="800" Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}">
    <DockPanel>
        <!-- ===== Top bar ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBg}" Padding="14,8"
                BorderBrush="{DynamicResource Accent}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Logo (left) -->
                <Image Grid.Column="0" Height="32" HorizontalAlignment="Left"
                       Source="pack://application:,,,/Assets/CustomHelpLogo.png" />

                <!-- App name (center) -->
                <TextBlock Grid.Column="1" Text="{Binding AppName}" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" />

                <!-- Version + status (right) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox Content="Telegramme mitschneiden" IsChecked="{Binding CaptureTelegrams}"
                              VerticalAlignment="Center" Margin="0,0,14,0"
                              ToolTip="Alle eingehenden Roh-Telegramme in den Capture-Ordner neben der EXE schreiben (Testfunktion)" />
                    <Button x:Name="ThemeToggle" Click="OnThemeToggle" Content="Theme"
                            Padding="8,3" Margin="0,0,14,0" ToolTip="Switch light / dark theme" />
                    <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,14,0" />
                    <Ellipse Width="12" Height="12" Fill="{Binding SystemStatusBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SystemStatus}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Status bar ===== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="{Binding SystemStatusBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SystemStatus}" Margin="6,0,0,0" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding ErrorCountText}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding UptimeText, StringFormat=Uptime {0}}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding HealthMessage}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding ConfigFile, StringFormat=Config: {0}}" /></StatusBarItem>
        </StatusBar>

        <!-- ===== Tabs ===== -->
        <TabControl Margin="6">
            <TabItem Header="Overview">
                <ctrl:ucOverviewControl />
            </TabItem>

            <TabItem Header="Cameras">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,6,6,0">
                        <Button Content="Settings anfordern" Command="{Binding RequestSettingsCommand}"
                                ToolTip="Settings-Telegramm von allen verbundenen Kameras anfordern" />
                        <TextBlock Text="{Binding SettingsRequestStatus}" VerticalAlignment="Center"
                                   Margin="12,0,0,0" Foreground="{DynamicResource TextDimBrush}" />
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Cameras}" Margin="6">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="4" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate><ctrl:ucCameraControl /></DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="SPS">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SpsChannels}" Margin="6">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><ctrl:ucSpsChannelControl /></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="MSA">
                <ctrl:ucMsaControl DataContext="{Binding Msa}" />
            </TabItem>

            <TabItem Header="Database">
                <ctrl:ucDatabaseControl />
            </TabItem>

            <TabItem Header="CSV">
                <ctrl:ucCsvControl />
            </TabItem>

            <TabItem Header="Collage">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ctrl:ucCollageControl />
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Tools">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tools}" Margin="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                                    <DockPanel>
                                        <Button Content="{Binding Name}" Command="{Binding LaunchCommand}"
                                                IsEnabled="{Binding IsAvailable}" Width="220"
                                                HorizontalAlignment="Left" />
                                        <TextBlock Text="{Binding Hint}" Foreground="{DynamicResource TextDimBrush}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Log">
                <ctrl:ucLogControl DataContext="{Binding Log}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
