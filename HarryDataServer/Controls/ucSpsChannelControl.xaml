<UserControl x:Class="HarryDataServer.Controls.ucSpsChannelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Margin="6" Width="340">
        <StackPanel>
            <DockPanel>
                <Ellipse Width="11" Height="11" Fill="{Binding ConnectedBrush}" DockPanel.Dock="Right" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis" />
            </DockPanel>
            <DockPanel Margin="0,2,0,8">
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource TextDimBrush}">
                    <Run Text="Msgs:" /><Run Text="{Binding Messages, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextDimBrush}">
                    <Run Text="Port" /><Run Text="{Binding Port, Mode=OneWay}" />
                </TextBlock>
            </DockPanel>

            <TextBlock Text="Last requests" Foreground="{StaticResource TextDimBrush}" FontSize="11" />
            <ListBox ItemsSource="{Binding LastRequests}" Height="44" Margin="0,2,0,6"
                     FontFamily="Consolas" FontSize="11" />

            <TextBlock Text="Last responses" Foreground="{StaticResource TextDimBrush}" FontSize="11" />
            <ListBox ItemsSource="{Binding LastResponses}" Height="44" Margin="0,2,0,0"
                     FontFamily="Consolas" FontSize="11" />
        </StackPanel>
    </Border>
</UserControl>
