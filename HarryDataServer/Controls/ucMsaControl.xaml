<UserControl x:Class="HarryDataServer.Controls.ucMsaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <!-- Tri-state result cell for the features grid: ok / not ok / n.a. -->
        <DataTemplate x:Key="ResultCell">
            <TextBlock Text="{Binding ResultText}" FontWeight="SemiBold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Gray" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ResultText}" Value="ok">
                                <Setter Property="Foreground" Value="SeaGreen" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ResultText}" Value="not ok">
                                <Setter Property="Foreground" Value="IndianRed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>

        <!-- Per-part verdict badge for the parts list -->
        <DataTemplate x:Key="PartVerdictCell">
            <Border CornerRadius="3" Padding="8,1" HorizontalAlignment="Left" Background="{Binding VerdictBrush}">
                <TextBlock Text="{Binding VerdictText}" Foreground="White" FontWeight="SemiBold" />
            </Border>
        </DataTemplate>

        <!-- Flat, full-width clickable row (deviation history) -->
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Deviation-history row template (shared by all three tabs) -->
        <DataTemplate x:Key="HistoryRow">
            <Button Style="{StaticResource RowButton}" Margin="0,1"
                    Command="{Binding DataContext.LoadRunCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding DateText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding BaseId}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextDimBrush}" />
                    <Border Grid.Column="2" CornerRadius="3" Padding="6,0" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Background="{Binding VerdictBrush}">
                        <TextBlock Text="{Binding VerdictText}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Grid.Column="3" Text="{Binding DeviationsText}" VerticalAlignment="Center"
                               Margin="6,0,0,0" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <TabControl ItemsSource="{Binding Modules}" SelectedItem="{Binding SelectedModule, Mode=TwoWay}" Margin="4">
        <TabControl.ItemTemplate>
            <DataTemplate>
                <TextBlock Text="{Binding Module}" FontWeight="SemiBold" />
            </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
            <DataTemplate>
                <!-- DataContext = MsaModuleViewModel -->
                <TabControl Margin="6" SelectedIndex="{Binding SelectedTypeIndex, Mode=TwoWay}">

                    <TabItem Header="MSA1">
                        <Grid Margin="8" DataContext="{Binding Msa1}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                                <Button Content="◀ Prev" Command="{Binding PreviousCommand}" DockPanel.Dock="Left" Margin="0,0,6,0" />
                                <Button Content="Next ▶" Command="{Binding NextCommand}" DockPanel.Dock="Left" Margin="0,0,12,0" />
                                <Border DockPanel.Dock="Left" Background="{Binding OverallBrush}" CornerRadius="4" Padding="10,3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding OverallText}" Foreground="White" FontWeight="Bold" />
                                </Border>
                                <Button DockPanel.Dock="Left" Margin="10,0,0,0" Content="New run available – click to load"
                                        Command="{Binding LoadNewestCommand}" Background="#F59E0B" Foreground="White"
                                        FontWeight="SemiBold" Padding="8,2" BorderThickness="0"
                                        Visibility="{Binding NewRunAvailable, Converter={StaticResource BoolToVis}}" />
                                <Button Content="Open Folder (Run)" Command="{Binding OpenFolderCommand}" DockPanel.Dock="Right" Margin="6,0,0,0" />
                                <Button Content="↻" Command="{Binding RefreshCommand}" DockPanel.Dock="Right" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding RunInfo}" VerticalAlignment="Center" Margin="12,0,8,0"
                                           Foreground="{DynamicResource TextDimBrush}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <TextBlock Grid.Row="1" Text="{Binding OverallReason}" Margin="0,0,0,8"
                                       Foreground="{DynamicResource LedOrange}" TextWrapping="Wrap" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0" Margin="0,0,8,0">
                                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="PDF Complete (Part)" Command="{Binding OpenAllResultsCommand}" Margin="0,0,6,0"
                                                ToolTipService.ShowOnDisabled="True" ToolTip="PDF of the SELECTED part — please select a part" />
                                        <Button Content="PDF Failures Only (Part)" Command="{Binding OpenFailuresOnlyCommand}"
                                                ToolTipService.ShowOnDisabled="True" ToolTip="Failures-only PDF of the SELECTED part — please select a part" />
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding Parts}" SelectedItem="{Binding SelectedPart}"
                                              AutoGenerateColumns="False" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Part (DMC)" Binding="{Binding DmcText}" Width="*" />
                                            <DataGridTemplateColumn Header="Verdict" CellTemplate="{StaticResource PartVerdictCell}" Width="90" />
                                            <DataGridTextColumn Header="ok" Binding="{Binding CountText}" Width="70" />
                                            <DataGridTextColumn Header="Reference" Binding="{Binding MatchedReference}" Width="Auto" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                                <DataGrid Grid.Column="1" ItemsSource="{Binding Features}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Measurement" Binding="{Binding DisplayName}" Width="2*" />
                                        <DataGridTextColumn Header="Cg" Binding="{Binding Cg, StringFormat=0.###}" Width="*" />
                                        <DataGridTextColumn Header="Cgk" Binding="{Binding Cgk, StringFormat=0.###}" Width="*" />
                                        <DataGridTemplateColumn Header="Result" CellTemplate="{StaticResource ResultCell}" Width="80" />
                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <DockPanel Grid.Row="3" Margin="0,8,0,0">
                                <TextBlock DockPanel.Dock="Top" Text="Deviation History (click to load)"
                                           FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                    <ItemsControl ItemsSource="{Binding History}" ItemTemplate="{StaticResource HistoryRow}" />
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="MSA3">
                        <Grid Margin="8" DataContext="{Binding Msa3}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                                <Button Content="◀ Prev" Command="{Binding PreviousCommand}" DockPanel.Dock="Left" Margin="0,0,6,0" />
                                <Button Content="Next ▶" Command="{Binding NextCommand}" DockPanel.Dock="Left" Margin="0,0,12,0" />
                                <Border DockPanel.Dock="Left" Background="{Binding OverallBrush}" CornerRadius="4" Padding="10,3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding OverallText}" Foreground="White" FontWeight="Bold" />
                                </Border>
                                <Button DockPanel.Dock="Left" Margin="10,0,0,0" Content="New run available – click to load"
                                        Command="{Binding LoadNewestCommand}" Background="#F59E0B" Foreground="White"
                                        FontWeight="SemiBold" Padding="8,2" BorderThickness="0"
                                        Visibility="{Binding NewRunAvailable, Converter={StaticResource BoolToVis}}" />
                                <Button Content="Open Folder (Run)" Command="{Binding OpenFolderCommand}" DockPanel.Dock="Right" Margin="6,0,0,0" />
                                <Button Content="↻" Command="{Binding RefreshCommand}" DockPanel.Dock="Right" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding RunInfo}" VerticalAlignment="Center" Margin="12,0,8,0"
                                           Foreground="{DynamicResource TextDimBrush}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <TextBlock Grid.Row="1" Text="{Binding OverallReason}" Margin="0,0,0,8"
                                       Foreground="{DynamicResource LedOrange}" TextWrapping="Wrap" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0" Margin="0,0,8,0">
                                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="PDF Complete (Part)" Command="{Binding OpenAllResultsCommand}" Margin="0,0,6,0"
                                                ToolTipService.ShowOnDisabled="True" ToolTip="PDF of the SELECTED part — please select a part" />
                                        <Button Content="PDF Failures Only (Part)" Command="{Binding OpenFailuresOnlyCommand}"
                                                ToolTipService.ShowOnDisabled="True" ToolTip="Failures-only PDF of the SELECTED part — please select a part" />
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding Parts}" SelectedItem="{Binding SelectedPart}"
                                              AutoGenerateColumns="False" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Part (DMC)" Binding="{Binding DmcText}" Width="*" />
                                            <DataGridTemplateColumn Header="Verdict" CellTemplate="{StaticResource PartVerdictCell}" Width="90" />
                                            <DataGridTextColumn Header="ok" Binding="{Binding CountText}" Width="70" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                                <DataGrid Grid.Column="1" ItemsSource="{Binding Features}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Measurement" Binding="{Binding DisplayName}" Width="2*" />
                                        <DataGridTextColumn Header="%Tolerance" Binding="{Binding PctTolerance, StringFormat=0.###}" Width="*" />
                                        <DataGridTemplateColumn Header="Result" CellTemplate="{StaticResource ResultCell}" Width="80" />
                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <DockPanel Grid.Row="3" Margin="0,8,0,0">
                                <TextBlock DockPanel.Dock="Top" Text="Deviation History (click to load)"
                                           FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                    <ItemsControl ItemsSource="{Binding History}" ItemTemplate="{StaticResource HistoryRow}" />
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="LimitSample">
                        <Grid Margin="8" DataContext="{Binding LimitSample}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                                <Button Content="◀ Prev" Command="{Binding PreviousCommand}" DockPanel.Dock="Left" Margin="0,0,6,0" />
                                <Button Content="Next ▶" Command="{Binding NextCommand}" DockPanel.Dock="Left" Margin="0,0,12,0" />
                                <Border DockPanel.Dock="Left" Background="{Binding OverallBrush}" CornerRadius="4" Padding="10,3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding OverallText}" Foreground="White" FontWeight="Bold" />
                                </Border>
                                <Button DockPanel.Dock="Left" Margin="10,0,0,0" Content="New run available – click to load"
                                        Command="{Binding LoadNewestCommand}" Background="#F59E0B" Foreground="White"
                                        FontWeight="SemiBold" Padding="8,2" BorderThickness="0"
                                        Visibility="{Binding NewRunAvailable, Converter={StaticResource BoolToVis}}" />
                                <Button Content="Open Folder (Run)" Command="{Binding OpenFolderCommand}" DockPanel.Dock="Right" Margin="6,0,0,0" />
                                <Button Content="↻" Command="{Binding RefreshCommand}" DockPanel.Dock="Right" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding RunInfo}" VerticalAlignment="Center" Margin="12,0,8,0"
                                           Foreground="{DynamicResource TextDimBrush}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <TextBlock Grid.Row="1" Text="{Binding OverallReason}" Margin="0,0,0,8"
                                       Foreground="{DynamicResource LedOrange}" TextWrapping="Wrap" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0" Margin="0,0,8,0">
                                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="PDF Complete (Part)" Command="{Binding OpenAllResultsCommand}" Margin="0,0,6,0"
                                                ToolTipService.ShowOnDisabled="True" ToolTip="PDF of the SELECTED part — please select a part" />
                                        <Button Content="PDF Failures Only (Part)" Command="{Binding OpenFailuresOnlyCommand}"
                                                ToolTipService.ShowOnDisabled="True" ToolTip="Failures-only PDF of the SELECTED part — please select a part" />
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding Parts}" SelectedItem="{Binding SelectedPart}"
                                              AutoGenerateColumns="False" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Part (DMC)" Binding="{Binding DmcText}" Width="*" />
                                            <DataGridTemplateColumn Header="Verdict" CellTemplate="{StaticResource PartVerdictCell}" Width="90" />
                                            <DataGridTextColumn Header="ok" Binding="{Binding CountText}" Width="70" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                                <DataGrid Grid.Column="1" ItemsSource="{Binding Features}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Measurement" Binding="{Binding DisplayName}" Width="2*" />
                                        <DataGridTextColumn Header="Expected" Binding="{Binding Expected}" Width="*" />
                                        <DataGridTextColumn Header="Actual" Binding="{Binding Actual}" Width="*" />
                                        <DataGridTemplateColumn Header="Result" CellTemplate="{StaticResource ResultCell}" Width="80" />
                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <DockPanel Grid.Row="3" Margin="0,8,0,0">
                                <TextBlock DockPanel.Dock="Top" Text="Deviation History (click to load)"
                                           FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                    <ItemsControl ItemsSource="{Binding History}" ItemTemplate="{StaticResource HistoryRow}" />
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </TabItem>

                </TabControl>
            </DataTemplate>
        </TabControl.ContentTemplate>
    </TabControl>
</UserControl>
