<UserControl x:Class="HarryDataServer.Controls.ucCsvControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="16" MaxWidth="760" HorizontalAlignment="Left">
        <TextBlock Text="CSV Export" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition /><RowDefinition /><RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Active file" Foreground="{StaticResource TextDimBrush}" Margin="0,3" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CsvActivePath}" Margin="0,3"
                           TextTrimming="CharacterEllipsis" FontFamily="Consolas" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Rows written" Foreground="{StaticResource TextDimBrush}" Margin="0,3" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CsvRows}" Margin="0,3" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last write" Foreground="{StaticResource TextDimBrush}" Margin="0,3" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CsvLastWrite}" Margin="0,3" />
            </Grid>
        </Border>

        <Border Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Part-exit timing" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBlock Text="{Binding ExportTiming}" FontFamily="Consolas" />
            </StackPanel>
        </Border>

        <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextDimBrush}">
            One row per finished part with every measurement value from every camera (two-row
            header), rotated on order change or when DataSetsPerFile rows are reached. After
            dmcserial is saved, CSV / Collage / image handling run in parallel, then the SPS
            channel-2 ACK is sent.
        </TextBlock>
    </StackPanel>
</UserControl>
