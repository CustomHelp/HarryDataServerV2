<UserControl x:Class="HarryDataServer.Controls.ucLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- DataContext is the LogViewModel -->
    <DockPanel Margin="6">
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Level:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextDimBrush}" />
                <Button Content="ALL" Command="{Binding AllCommand}" Margin="0,0,8,0" />
                <ToggleButton Content="INFO" IsChecked="{Binding ShowInfo}" />
                <ToggleButton Content="WARNING" IsChecked="{Binding ShowWarning}" />
                <ToggleButton Content="ERROR" IsChecked="{Binding ShowError}" />
                <Button Content="Export" Command="{Binding ExportCommand}" Margin="20,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Source:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextDimBrush}" />
                <ToggleButton Content="CAMERA" IsChecked="{Binding ShowCamera}" />
                <ToggleButton Content="SPS" IsChecked="{Binding ShowSps}" />
                <ToggleButton Content="DATABASE" IsChecked="{Binding ShowDatabase}" />
                <ToggleButton Content="CSV" IsChecked="{Binding ShowCsv}" />
                <ToggleButton Content="COLLAGE" IsChecked="{Binding ShowCollage}" />
                <ToggleButton Content="MSA" IsChecked="{Binding ShowMsa}" />
                <ToggleButton Content="SYSTEM" IsChecked="{Binding ShowSystem}" />
            </StackPanel>
        </StackPanel>

        <ListBox ItemsSource="{Binding Entries}" FontFamily="Consolas" FontSize="12"
                 VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}" TextWrapping="NoWrap" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
