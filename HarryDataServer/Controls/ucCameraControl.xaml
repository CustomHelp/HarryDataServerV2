<UserControl x:Class="HarryDataServer.Controls.ucCameraControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Margin="6">
        <StackPanel>
            <!-- Header -->
            <DockPanel>
                <TextBlock Text="{Binding Module}" DockPanel.Dock="Right" Foreground="{DynamicResource AccentLight}"
                           FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
            <TextBlock Margin="0,2,0,6" Foreground="{DynamicResource TextDimBrush}">
                <Run Text="{Binding Ip, Mode=OneWay}" /><Run Text=":" /><Run Text="{Binding Port, Mode=OneWay}" />
            </TextBlock>

            <!-- Last-received operating mode + independent diagnostic badge -->
            <DockPanel Margin="0,0,0,8">
                <Border DockPanel.Dock="Right" CornerRadius="3" Padding="6,1" BorderThickness="1"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDiagnostic}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Accent}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Diagnose" FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDiagnostic}" Value="True">
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <TextBlock Text="{Binding ModeText}" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentLight}" TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <!-- LEDs -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Ellipse Width="11" Height="11" Fill="{Binding JsonBrush}" VerticalAlignment="Center" />
                <TextBlock Text="JSON" Margin="5,0,14,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
                <Ellipse Width="11" Height="11" Fill="{Binding ConnectedBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Conn" Margin="5,0,14,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
                <Ellipse Width="11" Height="11" Fill="{Binding ReconnectBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Auto" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
            </StackPanel>

            <DockPanel Margin="0,0,0,6">
                <TextBlock Text="{Binding StateText}" DockPanel.Dock="Right" FontWeight="SemiBold" />
                <TextBlock>
                    <Run Text="Telegrams:" Foreground="{DynamicResource TextDimBrush}" />
                    <Run Text="{Binding TelegramCount, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
            </DockPanel>

            <!-- Last 3 telegrams -->
            <TextBlock Text="Last telegrams" Foreground="{DynamicResource TextDimBrush}" FontSize="11" />
            <ListBox ItemsSource="{Binding RecentTelegrams}" Height="62" Margin="0,2,0,8"
                     FontFamily="Consolas" FontSize="11" BorderThickness="1" />

            <Button Content="Reconnect" Command="{Binding ReconnectCommand}" HorizontalAlignment="Right" />
        </StackPanel>
    </Border>
</UserControl>
