<UserControl x:Class="HarryDataServer.Controls.ucCameraControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Margin="6" Width="280">
        <StackPanel>
            <!-- Header -->
            <DockPanel>
                <TextBlock Text="{Binding Module}" DockPanel.Dock="Right" Foreground="{StaticResource AccentLight}"
                           FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
            <TextBlock Margin="0,2,0,8" Foreground="{StaticResource TextDimBrush}">
                <Run Text="{Binding Ip, Mode=OneWay}" /><Run Text=":" /><Run Text="{Binding Port, Mode=OneWay}" />
            </TextBlock>

            <!-- LEDs -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Ellipse Width="11" Height="11" Fill="{Binding JsonBrush}" VerticalAlignment="Center" />
                <TextBlock Text="JSON" Margin="5,0,14,0" VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}" />
                <Ellipse Width="11" Height="11" Fill="{Binding ConnectedBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Conn" Margin="5,0,14,0" VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}" />
                <Ellipse Width="11" Height="11" Fill="{Binding ReconnectBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Auto" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}" />
            </StackPanel>

            <DockPanel Margin="0,0,0,6">
                <TextBlock Text="{Binding StateText}" DockPanel.Dock="Right" FontWeight="SemiBold" />
                <TextBlock>
                    <Run Text="Telegrams:" Foreground="{StaticResource TextDimBrush}" />
                    <Run Text="{Binding TelegramCount, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
            </DockPanel>

            <!-- Last 3 telegrams -->
            <TextBlock Text="Last telegrams" Foreground="{StaticResource TextDimBrush}" FontSize="11" />
            <ListBox ItemsSource="{Binding RecentTelegrams}" Height="62" Margin="0,2,0,8"
                     FontFamily="Consolas" FontSize="11" BorderThickness="1" />

            <Button Content="Reconnect" Command="{Binding ReconnectCommand}" HorizontalAlignment="Right" />
        </StackPanel>
    </Border>
</UserControl>
