<UserControl x:Class="HarryDataServer.Controls.ucCameraControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Margin="6">
        <StackPanel>
            <!-- Header on a single line (name · ip:port · module) to leave room for more list lines (task D) -->
            <DockPanel Margin="0,0,0,6">
                <TextBlock Text="{Binding Module}" DockPanel.Dock="Right" Foreground="{DynamicResource AccentLight}"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" />
                <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource TextDimBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0">
                    <Run Text="{Binding Ip, Mode=OneWay}" /><Run Text=":" /><Run Text="{Binding Port, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" FontWeight="Bold" FontSize="13"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
            </DockPanel>

            <!-- Last-received operating mode + independent diagnostic badge -->
            <DockPanel Margin="0,0,0,8">
                <Border DockPanel.Dock="Right" CornerRadius="3" Padding="6,1" BorderThickness="1"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDiagnostic}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Accent}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Diagnostic" FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDiagnostic}" Value="True">
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <TextBlock Text="{Binding ModeText}" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentLight}" TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <!-- LEDs -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Ellipse Width="11" Height="11" Fill="{Binding JsonBrush}" VerticalAlignment="Center" />
                <TextBlock Text="JSON" Margin="5,0,14,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
                <Ellipse Width="11" Height="11" Fill="{Binding ConnectedBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Conn" Margin="5,0,14,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
                <Ellipse Width="11" Height="11" Fill="{Binding ReconnectBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Auto" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
            </StackPanel>

            <DockPanel Margin="0,0,0,6">
                <TextBlock Text="{Binding StateText}" DockPanel.Dock="Right" FontWeight="SemiBold" />
                <TextBlock>
                    <Run Text="Telegrams:" Foreground="{DynamicResource TextDimBrush}" />
                    <Run Text="{Binding TelegramCount, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
            </DockPanel>

            <!-- Last telegrams (≥ 4 lines visible; right-click a line to copy its serial) -->
            <TextBlock Text="Last telegrams" Foreground="{DynamicResource TextDimBrush}" FontSize="11" />
            <ListBox ItemsSource="{Binding RecentTelegrams}" Height="100" Margin="0,2,0,8"
                     FontFamily="Consolas" FontSize="11" BorderThickness="1"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- Transparent background so the whole row is right-clickable. Each item
                             gets its own ContextMenu (per-item DataContext = the RecentTelegram).
                             Trims with an ellipsis and shows the full line as a tooltip (task B/D). -->
                        <TextBlock Text="{Binding Text}" ToolTip="{Binding Text}" Background="Transparent"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Copy Serial Number" Click="OnCopySerial" />
                                </ContextMenu>
                            </TextBlock.ContextMenu>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Content="Reconnect" Command="{Binding ReconnectCommand}" HorizontalAlignment="Right" />
        </StackPanel>
    </Border>
</UserControl>
