<UserControl x:Class="HarryDataServer.Controls.ucCollageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- DataContext is the MainViewModel -->
    <StackPanel Margin="16">
        <TextBlock Text="Collage Generator" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
        <TextBlock Text="{Binding CollageText}" FontSize="14" Margin="0,0,0,8" />

        <Border Style="{StaticResource Card}" HorizontalAlignment="Left" MaxWidth="700">
            <StackPanel>
                <TextBlock Text="Part-exit timing" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBlock Text="{Binding ExportTiming}" FontFamily="Consolas" />
            </StackPanel>
        </Border>

        <TextBlock Text="Last 4 collages" FontWeight="Bold" Margin="0,16,0,6" />
        <ItemsControl ItemsSource="{Binding CollageView.Thumbnails}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Margin="6" Padding="6">
                        <StackPanel>
                            <Image Source="{Binding Image}" MaxHeight="180" Stretch="Uniform" />
                            <TextBlock Text="{Binding Timestamp}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Collages appear here as they are generated (OK parts, when Collage_Generate=true)."
                   Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,8,0,0" />
    </StackPanel>
</UserControl>
