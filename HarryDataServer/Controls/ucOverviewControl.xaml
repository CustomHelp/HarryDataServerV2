<UserControl x:Class="HarryDataServer.Controls.ucOverviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- DataContext is the MainViewModel -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="900">
            <TextBlock Text="Overview" FontSize="20" FontWeight="Bold" Margin="0,0,0,14" />

            <WrapPanel>
                <!-- Cameras -->
                <Border Style="{StaticResource Card}" Width="270" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Cameras" Foreground="{DynamicResource TextDimBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse Width="14" Height="14" Fill="{Binding OverviewCamerasBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding OverviewCameras}" FontSize="16" FontWeight="Bold" Margin="8,0,0,0" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding OfflineCameras}" Margin="0,6,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource LedOrange}" FontSize="11" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Today's parts -->
                <Border Style="{StaticResource Card}" Width="270" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Today's parts" Foreground="{DynamicResource TextDimBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Background="{StaticResource LedGreen}" CornerRadius="4" Padding="12,4" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="OK" Foreground="White" FontSize="11" />
                                    <TextBlock Text="{Binding TodayOk}" Foreground="White" FontSize="18" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource LedRed}" CornerRadius="4" Padding="12,4">
                                <StackPanel>
                                    <TextBlock Text="NG" Foreground="White" FontSize="11" />
                                    <TextBlock Text="{Binding TodayNg}" Foreground="White" FontSize="18" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Order / last exit -->
                <Border Style="{StaticResource Card}" Width="270" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Active order" Foreground="{DynamicResource TextDimBrush}" />
                        <TextBlock Text="{Binding ActiveOrder}" FontSize="16" FontWeight="Bold" Margin="0,4,0,10"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="Last part exit" Foreground="{DynamicResource TextDimBrush}" />
                        <TextBlock Text="{Binding LastPartExit}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Active errors -->
            <TextBlock Text="Active errors" FontWeight="Bold" Margin="0,10,0,6" />
            <ItemsControl ItemsSource="{Binding HealthFaults}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="{StaticResource LedRed}" Margin="0,2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="No active errors — all systems nominal." Foreground="{StaticResource LedGreen}"
                       Margin="0,2" Visibility="{Binding IsHealthy, Converter={StaticResource BoolToVisible}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
