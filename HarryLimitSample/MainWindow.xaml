<Window x:Class="HarryLimitSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HarryLimitSample" Height="780" Width="1240"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}" />
    </Window.InputBindings>
    <DockPanel>
        <!-- ===== Top bar ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBg}" Padding="14,8"
                BorderBrush="{DynamicResource Accent}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Height="32" HorizontalAlignment="Left"
                       Source="pack://application:,,,/HarryShared;component/Assets/CustomHelpLogo.png" />
                <TextBlock Grid.Column="1" Text="{Binding AppName}" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="11" Height="11" Fill="{Binding ScannerLed}" VerticalAlignment="Center"
                             Margin="0,0,6,0" ToolTip="{Binding ScannerStatus}" />
                    <ToggleButton Content="Scanner" IsChecked="{Binding ScannerActive}" Padding="8,3"
                                  Margin="0,0,12,0"
                                  ToolTip="Auto-search when a code arrives from the handheld scanner" />
                    <Button Click="OnChangeConfig" Content="Config…" Padding="8,3" Margin="0,0,12,0"
                            ToolTip="Change config path… (which Harry.ini this tool uses)" />
                    <Button x:Name="ThemeToggle" Click="OnThemeToggle" Content="Theme"
                            Padding="8,3" Margin="0,0,12,0" ToolTip="Switch light / dark theme" />
                    <Button Content="?" Command="{Binding ShowHelpCommand}" Padding="10,3" Margin="0,0,12,0"
                            FontWeight="Bold" ToolTip="Help (F1)" />
                    <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource TextDimBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Status bar ===== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding ReferenceFolder, StringFormat=Ref folder: {0}}" /></StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="Scan / Serial:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                    <TextBox x:Name="ScanBox" Width="300" VerticalAlignment="Center"
                             Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Search" Command="{Binding SearchCommand}" Margin="8,0,16,0" Width="80" />

                    <TextBlock Text="Module:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="120" ItemsSource="{Binding Modules}" SelectedItem="{Binding SelectedModule}"
                              VerticalAlignment="Center" Margin="0,0,16,0" />
                    <TextBlock Text="MSA version:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="80" Text="{Binding MsaVersion}" VerticalAlignment="Center" Margin="0,0,16,0" />

                    <Button Content="Load existing" Command="{Binding LoadExistingCommand}" Margin="0,0,4,0" />
                    <Button Content="Clear marks" Command="{Binding ClearMarksCommand}" Margin="0,0,4,0" />
                </WrapPanel>
            </Border>

            <!-- Not-found banner -->
            <Border Grid.Row="1" Background="#FFEF4444" CornerRadius="4" Padding="10,6" Margin="0,0,0,8"
                    Visibility="{Binding NotFound, Converter={StaticResource BoolToVisible}}">
                <TextBlock Text="{Binding NotFoundText}" Foreground="White" FontWeight="Bold" />
            </Border>

            <!-- ===== Save bar (always visible) ===== -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,8" Padding="12,8">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Save reference  (Ctrl+S)"
                            Command="{Binding SaveCommand}" VerticalAlignment="Center"
                            Width="230" Padding="12,10" FontWeight="Bold" FontSize="14"
                            Background="{DynamicResource Accent}" Foreground="White"
                            ToolTip="Save the marks in the table as this part's reference file (Ctrl+S)" />
                    <TextBlock Text="{Binding SavePathPreview}" VerticalAlignment="Center" Margin="0,0,12,0"
                               Foreground="{DynamicResource TextDimBrush}" TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>

            <!-- Measurement grid (left) + taught-parts list (right) -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="460" />
                </Grid.ColumnDefinitions>

                <DataGrid Grid.Column="0" ItemsSource="{Binding Rows}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Measurement" Binding="{Binding DisplayName}" Width="*" MinWidth="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Setter Property="ToolTip" Value="{Binding DisplayName}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="Auto" MinWidth="44" />
                        <DataGridTextColumn Header="Camera" Binding="{Binding CameraName}" Width="Auto" />
                        <DataGridTextColumn Header="Value" Binding="{Binding ValueText}" Width="70" />
                        <DataGridTextColumn Header="Result" Binding="{Binding ResultText}" Width="70" />
                        <DataGridTemplateColumn Header="Expectation" Width="190" MinWidth="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedItem="{Binding Expectation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding DataContext.Expectations, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Margin="2" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Taught parts of the selected module (per-part reference files) -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Taught parts (this module + identical mirror)" FontWeight="SemiBold"
                                   Margin="0,0,0,6" TextWrapping="Wrap" />
                        <TextBlock DockPanel.Dock="Bottom" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                   TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="Includes the identical partner module (M10↔M11, M20↔M21). Open re-loads a part for editing; Delete removes its reference file." />
                        <DataGrid ItemsSource="{Binding TaughtParts}" AutoGenerateColumns="False"
                                  IsReadOnly="True" HeadersVisibility="Column"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DMC" Binding="{Binding Dmc}" Width="*" MinWidth="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="ToolTip" Value="{Binding Dmc}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="Auto" MinWidth="44" />
                                <DataGridTextColumn Header="Taught" Binding="{Binding TaughtAt, StringFormat=yyyy-MM-dd HH:mm}" Width="Auto" />
                                <DataGridTextColumn Header="#Fail" Binding="{Binding ExpectedFailCount}" Width="Auto" />
                                <!-- Fixed width so Open/Delete are ALWAYS fully visible (never clipped at the edge). -->
                                <DataGridTemplateColumn Header="Action" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Open" Margin="2" Padding="8,2"
                                                        Command="{Binding DataContext.OpenTaughtPartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Content="Delete" Margin="2" Padding="8,2"
                                                        Command="{Binding DataContext.DeleteTaughtPartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
