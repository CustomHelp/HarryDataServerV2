<Window x:Class="HarryAnalysis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HarryAnalysis" Height="840" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}">
    <DockPanel>
        <!-- ===== Top bar ===== -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBg}" Padding="14,8"
                BorderBrush="{StaticResource Accent}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Height="32" HorizontalAlignment="Left"
                       Source="pack://application:,,,/HarryShared;component/Assets/CustomHelpLogo.png" />
                <TextBlock Grid.Column="1" Text="{Binding AppName}" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding AppVersion}" Foreground="{StaticResource TextDimBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ===== Status bar ===== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding ConfigFile, StringFormat=Config: {0}}" /></StatusBarItem>
        </StatusBar>

        <!-- ===== Scan bar ===== -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="8,8,8,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Scan / Serial:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                <TextBox x:Name="ScanBox" Width="360" VerticalAlignment="Center" FontSize="14"
                         Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Search" Command="{Binding SearchCommand}" Margin="8,0,0,0" Width="90" />
                <TextBlock Text="(DMC · SZID · VirtualSerial)" Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>
        </Border>

        <!-- ===== Split: history (top) / detail (bottom) ===== -->
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="200" MinHeight="120" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- History list -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="6">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="Scan history (last 20)" FontWeight="Bold" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Content="Clear All" Command="{Binding ClearAllCommand}"
                                HorizontalAlignment="Right" Width="90" />
                    </DockPanel>
                    <DataGrid x:Name="HistoryGrid" ItemsSource="{Binding History}"
                              SelectedItem="{Binding SelectedEntry}" CanUserSortColumns="True">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove this entry"
                                          Command="{Binding PlacementTarget.DataContext.RemoveSelectedEntryCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampText}" Width="160" />
                            <DataGridTextColumn Header="DMC" Binding="{Binding Dmc}" Width="2*" />
                            <DataGridTextColumn Header="SZID" Binding="{Binding Szid}" Width="2*" />
                            <DataGridTextColumn Header="Matched" Binding="{Binding MatchedField}" Width="110" />
                            <DataGridTemplateColumn Header="Result" Width="90" SortMemberPath="ResultStatus">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left"
                                                Background="{Binding ResultStatus, Converter={StaticResource ResultStatusToBrush}}">
                                            <TextBlock Text="{Binding ResultText}" Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" />

            <!-- Detail panel -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header card -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,4,0,8">
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="4" Padding="10,4" VerticalAlignment="Center" Margin="0,0,12,0"
                                Background="{Binding Part.ResultStatus, Converter={StaticResource ResultStatusToBrush}}"
                                Visibility="{Binding ResultBadge, Converter={StaticResource NullToVisible}}">
                            <TextBlock Text="{Binding ResultBadge}" Foreground="White" FontWeight="Bold" FontSize="14" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding MatchedFieldText}" Foreground="{StaticResource TextDimBrush}"
                                       FontStyle="Italic" Margin="0,0,0,2"
                                       Visibility="{Binding MatchedFieldText, Converter={StaticResource NullToVisible}}" />
                            <TextBlock Text="{Binding HeaderInfo}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Measurements grid -->
                <DockPanel Grid.Row="1">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="Measurements (click a column header to sort)" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Content="Export CSV" Command="{Binding ExportCommand}"
                                HorizontalAlignment="Right" Width="100" />
                    </DockPanel>
                    <DataGrid ItemsSource="{Binding Measurements}" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Measurement" Binding="{Binding DisplayName}" Width="2*" />
                            <DataGridTextColumn Header="Camera" Binding="{Binding CameraName}" Width="*" />
                            <DataGridTextColumn Header="Feature Group" Binding="{Binding FeatureGroup}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value, StringFormat=0.00}" Width="90" />
                            <DataGridTextColumn Header="Min" Binding="{Binding Min, StringFormat=0.00}" Width="80" />
                            <DataGridTextColumn Header="Max" Binding="{Binding Max, StringFormat=0.00}" Width="80" />
                            <DataGridTemplateColumn Header="Result" Width="110" SortMemberPath="ResultStatus">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left"
                                                Background="{Binding ResultStatus, Converter={StaticResource ResultStatusToBrush}}">
                                            <TextBlock Text="{Binding ResultText}" Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Measured At"
                                                Binding="{Binding MeasuredAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
