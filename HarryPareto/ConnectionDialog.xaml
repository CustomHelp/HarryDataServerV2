<Window x:Class="HarryPareto.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HarryPareto — Connection" Height="360" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBg}">
    <Border Style="{StaticResource Card}" Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Connection to the MySQL database (read-only)"
                       FontWeight="Bold" FontSize="14" Margin="0,0,0,12" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="IP / Host" VerticalAlignment="Center" Margin="0,4" />
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="IpBox" Margin="0,4" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Port" VerticalAlignment="Center" Margin="0,4" />
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="PortBox" Margin="0,4" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Database" VerticalAlignment="Center" Margin="0,4" />
            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="DbBox" Margin="0,4" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="User" VerticalAlignment="Center" Margin="0,4" />
            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="UserBox" Margin="0,4" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Password" VerticalAlignment="Center" Margin="0,4" />
            <PasswordBox Grid.Row="5" Grid.Column="1" x:Name="PwBox" Margin="0,4" Padding="6,4"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />

            <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,10,0,6">
                <Ellipse x:Name="StatusLed" Width="12" Height="12" Fill="Gray" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText" Text="Please test the connection." Margin="8,0,0,0"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Connect" Click="OnConnect" Margin="0,0,8,0" MinWidth="110" />
                <Button Content="Cancel" Click="OnCancel" MinWidth="90"
                        Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextBrush}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
