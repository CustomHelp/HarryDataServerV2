<Window x:Class="HarryPareto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HarryPareto"
        Title="HarryPareto" Height="860" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}">
    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </Window.InputBindings>

    <Grid>
        <!-- LayoutTransform scales the whole UI for the TV/wall-display mode (task E3). -->
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
        </Grid.LayoutTransform>

        <DockPanel>
            <!-- ===== Top bar ===== -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBg}" Padding="14,8"
                    BorderBrush="{DynamicResource Accent}" BorderThickness="0,0,0,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Height="32" HorizontalAlignment="Left"
                           Source="pack://application:,,,/HarryShared;component/Assets/CustomHelpLogo.png" />
                    <TextBlock Grid.Column="1" Text="{Binding AppName}" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ToggleButton Content="TV-Modus" IsChecked="{Binding TvMode}" Margin="0,0,12,0"
                                      ToolTip="Vollbild-taugliche große Darstellung" />
                        <Button x:Name="ThemeToggle" Click="OnThemeToggle" Content="Theme"
                                Padding="8,3" Margin="0,0,12,0" ToolTip="Light / Dark umschalten" />
                        <Button Content="?" Command="{Binding ShowHelpCommand}" Padding="10,3" Margin="0,0,12,0"
                                FontWeight="Bold" ToolTip="Hilfe / Help (F1)" />
                        <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource TextDimBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== Status bar ===== -->
            <StatusBar DockPanel.Dock="Bottom">
                <StatusBarItem><TextBlock Text="{Binding StatusMessage}" /></StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="11" Height="11" Fill="{Binding ConnectionBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ConnectionText}" Margin="6,0,0,0" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <!-- ===== Toolbar ===== -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="8,8,8,0">
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="Zeitfenster:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" />
                    <ComboBox Width="120" ItemsSource="{Binding WindowOptions}" SelectedItem="{Binding SelectedWindow}"
                              VerticalAlignment="Center" Margin="0,0,16,0" />
                    <TextBlock Text="Controller:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" />
                    <ComboBox Width="200" ItemsSource="{Binding Controllers}" SelectedItem="{Binding SelectedController}"
                              VerticalAlignment="Center" Margin="0,0,16,0" />
                    <TextBlock Text="Auto-Refresh (s):" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="56" Text="{Binding RefreshSeconds, UpdateSourceTrigger=LostFocus}"
                             VerticalAlignment="Center" Margin="0,0,6,0" ToolTip="Aktualisierungsintervall in Sekunden (min. 5)" />
                    <CheckBox Content="Auto" IsChecked="{Binding AutoRefresh}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <ToggleButton Content="Nach Kamera trennen" IsChecked="{Binding SeparateByCamera}"
                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                  ToolTip="AUS: KF1/KF3 einer Station zusammenfassen (Standard). EIN: je Kamera getrennt." />
                    <ToggleButton Content="Sensoren einzeln" IsChecked="{Binding SensorsIndividual}"
                                  VerticalAlignment="Center" Margin="0,0,16,0"
                                  ToolTip="AUS: _S1..S5 zu einer Sensor-Familie zusammenfassen (Standard). EIN: jeden Sensor einzeln." />
                    <Button Content="Aktualisieren" Command="{Binding RefreshCommand}" Margin="0,0,6,0" />
                    <Button Content="CSV-Export" Command="{Binding ExportCsvCommand}" Margin="0,0,6,0" />
                    <Button Content="Verbindung…" Command="{Binding ReconnectCommand}" Margin="0,0,16,0" />
                    <Border Background="{DynamicResource Accent}" CornerRadius="3" Padding="8,3"
                            VerticalAlignment="Center" Margin="0,0,6,0"
                            Visibility="{Binding HasModuleFilter, Converter={StaticResource BoolToVisible}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ModuleFilterText}" Foreground="White" VerticalAlignment="Center" />
                            <Button Content="✕" Command="{Binding ClearModuleFilterCommand}" Margin="8,0,0,0"
                                    Padding="4,0" Background="Transparent" Foreground="White" />
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Border>

            <!-- ===== KPI head ===== -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="8,8,8,0">
                <UniformGrid Rows="1" Columns="5">
                    <StackPanel Margin="4">
                        <TextBlock Text="Geprüfte Teile" Foreground="{DynamicResource TextDimBrush}" FontSize="12" />
                        <TextBlock Text="{Binding InspectedText}" FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel Margin="4">
                        <TextBlock Text="Schlechtteile" Foreground="{DynamicResource TextDimBrush}" FontSize="12" />
                        <TextBlock Text="{Binding BadText}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource LedRed}" />
                    </StackPanel>
                    <StackPanel Margin="4">
                        <TextBlock Text="Quote" Foreground="{DynamicResource TextDimBrush}" FontSize="12" />
                        <TextBlock Text="{Binding RateText}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource LedOrange}" />
                    </StackPanel>
                    <StackPanel Margin="4">
                        <TextBlock Text="Zeitfenster" Foreground="{DynamicResource TextDimBrush}" FontSize="12" />
                        <TextBlock Text="{Binding WindowText}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="4">
                        <TextBlock Text="Zuletzt aktualisiert" Foreground="{DynamicResource TextDimBrush}" FontSize="12" />
                        <TextBlock Text="{Binding UpdatedText}" FontSize="14" FontWeight="SemiBold" />
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- ===== Shift comparison ===== -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="8,8,8,0">
                <TextBlock>
                    <Run Text="Schichtvergleich:  " FontWeight="SemiBold" />
                    <Run Text="{Binding ShiftComparisonText, Mode=OneWay}" />
                </TextBlock>
            </Border>

            <!-- ===== Status-2 warnings ===== -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="8,8,8,0"
                    Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVisible}}">
                <StackPanel>
                    <TextBlock Text="Kameras ohne Bewertung (Status 2)" FontWeight="SemiBold"
                               Foreground="{DynamicResource LedOrange}" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding Status2Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{DynamicResource LedOrange}" Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== Main content: Pareto bars (left) + module chart (right) ===== -->
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Top-20 pareto -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Top 20 Fehlergründe — betroffene Teile"
                                   FontWeight="Bold" FontSize="15" Margin="0,0,0,6" />
                        <TextBlock DockPanel.Dock="Top" Text="(Balken anklicken = Herkunft Modul/Nest · Stack = je Kamera)"
                                   Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,0,0,6" />
                        <!-- Legend -->
                        <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Legend}" Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <Border Width="14" Height="14" CornerRadius="3" Background="{Binding Brush}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ModuleRef}" Margin="5,0,0,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextDimBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Bars}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,2" ToolTip="{Binding ToolTipText}" Cursor="Hand"
                                                HorizontalContentAlignment="Stretch" Padding="2" Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.ShowOriginCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                                            CornerRadius="3">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="270" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="170" />
                                                    <ColumnDefinition Width="26" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                                <local:SegmentBar Grid.Column="1" Height="20" VerticalAlignment="Center"
                                                                  Segments="{Binding Segments}"
                                                                  RemainderWeight="{Binding RemainderWeight}"
                                                                  TrackBrush="{DynamicResource CardBg}" />
                                                <TextBlock Grid.Column="2" Text="{Binding CountText}" VerticalAlignment="Center"
                                                           Margin="8,0,0,0" />
                                                <TextBlock Grid.Column="3" Text="{Binding TrendGlyph}" Foreground="{Binding TrendBrush}"
                                                           FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}" />

                <!-- Module chart (click a bar to filter the list) -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Fehleranteile je Herkunftsmodul" FontWeight="Bold"
                                   FontSize="15" Margin="0,0,0,6" />
                        <TextBlock DockPanel.Dock="Top" Text="(M10/M11, M20/M21 aus dmcserial · unbekannt = noch kein Teile-Austritt · anklicken filtert oben)"
                                   Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,0,0,8"
                                   TextWrapping="Wrap" />
                        <ListBox ItemsSource="{Binding ModuleBars}" SelectedItem="{Binding SelectedModuleBar}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ModuleRef}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="0,0,6,0" />
                                        <ProgressBar Grid.Column="1" Height="18" VerticalAlignment="Center"
                                                     Minimum="0" Maximum="100" Value="{Binding BarFraction, Mode=OneWay}"
                                                     Foreground="{Binding BarBrush}" Background="{DynamicResource CardBg}"
                                                     BorderThickness="0" />
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" VerticalAlignment="Center"
                                                   Margin="6,0,0,0" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- ===== Origin detail overlay (task A) ===== -->
                <Border Grid.Column="0" Grid.ColumnSpan="3" Background="#B3000000"
                        Visibility="{Binding HasOriginDetail, Converter={StaticResource BoolToVisible}}">
                    <Border Style="{StaticResource Card}" Margin="40" MaxWidth="1100" MaxHeight="640"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                <TextBlock Text="{Binding OriginTitle}" FontWeight="Bold" FontSize="16"
                                           TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" />
                                <Button Content="✕ Schließen" Command="{Binding CloseOriginCommand}"
                                        HorizontalAlignment="Right" Padding="10,3" />
                            </Grid>
                            <TextBlock DockPanel.Dock="Top" Text="{Binding OriginSubtitle}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,0,0,10" />
                            <TextBlock DockPanel.Dock="Top" Text="{Binding OriginNote}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource LedOrange}" Margin="0,0,0,8"
                                       Visibility="{Binding HasOriginNote, Converter={StaticResource BoolToVisible}}" />

                            <Grid Visibility="{Binding HasOriginMatrix, Converter={StaticResource BoolToVisible}}">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <!-- Header: nest columns -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="Herkunftsmodul \ Nest" Width="150" FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <ItemsControl ItemsSource="{Binding OriginNests}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Width="92" FontWeight="Bold"
                                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                                   Margin="1,0" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <!-- One row per origin module -->
                                        <ItemsControl ItemsSource="{Binding OriginRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                                        <TextBlock Text="{Binding Module}" Width="150" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" />
                                                        <ItemsControl ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="92" Margin="1" CornerRadius="3" Padding="4,3"
                                                                            Background="{DynamicResource CardBg}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsElevated}" Value="True">
                                                                                        <Setter Property="Background" Value="#66EF4444" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Text}" TextAlignment="Center" FontWeight="SemiBold" />
                                                                            <TextBlock Text="{Binding RateText}" TextAlignment="Center"
                                                                                       Foreground="{DynamicResource TextDimBrush}" FontSize="11" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="Zelle: betroffene / geprüfte Teile · darunter die Fehlerrate. Rot hinterlegt = deutlich überhöhte Rate."
                                                   Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,10,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
