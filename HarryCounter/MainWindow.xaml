<Window x:Class="HarryCounter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="HarryCounter" Height="820" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}">
    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}" />
    </Window.InputBindings>
    <DockPanel>
        <!-- ===== Top bar ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBg}" Padding="14,8"
                BorderBrush="{DynamicResource Accent}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Height="32" HorizontalAlignment="Left"
                       Source="pack://application:,,,/HarryShared;component/Assets/CustomHelpLogo.png" />
                <TextBlock Grid.Column="1" Text="{Binding AppName}" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Click="OnChangeConfig" Content="Config…" Padding="8,3" Margin="0,0,12,0"
                            ToolTip="Change config path… (which Harry.ini this tool uses)" />
                    <Button x:Name="ThemeToggle" Click="OnThemeToggle" Content="Theme"
                            Padding="8,3" Margin="0,0,12,0" ToolTip="Switch light / dark theme" />
                    <Button Content="?" Command="{Binding ShowHelpCommand}" Padding="10,3" Margin="0,0,12,0"
                            FontWeight="Bold" ToolTip="Help / Hilfe (F1)" />
                    <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource TextDimBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Status bar ===== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding ConfigFile, StringFormat=Config: {0}}" /></StatusBarItem>
        </StatusBar>

        <!-- ===== Filter bar ===== -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="8,8,8,0">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Group by:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" />
                <ComboBox Width="150" ItemsSource="{Binding Dimensions}" SelectedItem="{Binding Level1}"
                          VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBlock Text="→" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox Width="150" ItemsSource="{Binding Dimensions}" SelectedItem="{Binding Level2}"
                          VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBlock Text="→" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox Width="150" ItemsSource="{Binding Dimensions}" SelectedItem="{Binding Level3}"
                          VerticalAlignment="Center" Margin="0,0,16,0" />

                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <DatePicker SelectedDate="{Binding FromDate}" Width="120" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Width="70" Text="{Binding FromTime, StringFormat=hh\\:mm\\:ss}" VerticalAlignment="Center"
                         Margin="0,0,10,0" ToolTip="From time of day (HH:mm:ss)" />
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <DatePicker SelectedDate="{Binding ToDate}" Width="120" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Width="70" Text="{Binding ToTime, StringFormat=hh\\:mm\\:ss}" VerticalAlignment="Center"
                         Margin="0,0,12,0" ToolTip="To time of day (HH:mm:ss)" />
                <Button Content="Today" Command="{Binding RangeTodayCommand}" Margin="0,0,4,0" />
                <Button Content="7 days" Command="{Binding Range7DaysCommand}" Margin="0,0,4,0" />
                <Button Content="30 days" Command="{Binding Range30DaysCommand}" Margin="0,0,12,0" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0,0,4,0" />
                <Button Content="Export CSV" Command="{Binding ExportCommand}" Margin="0,0,4,0" />
                <Button Content="Reset Tree" Command="{Binding ResetTreeCommand}" Margin="0,0,12,0"
                        ToolTip="Collapse the tree back to the default state" />
                <CheckBox Content="Live (5 s)" IsChecked="{Binding LiveMode}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Text="last N:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox Width="90" IsEditable="True" ItemsSource="{Binding LiveCountPresets}"
                          Text="{Binding LiveCountText, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center"
                          ToolTip="Live view: aggregate over the most recent N finished parts (presets or custom)" />
            </WrapPanel>
        </Border>

        <!-- ===== Summary ===== -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="8,8,8,0">
            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" />
        </Border>

        <!-- ===== Error tree (left) + bar chart (right) ===== -->
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <TreeView ItemsSource="{Binding Tree}" Background="Transparent" BorderThickness="0">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="{x:Type TreeViewItem}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}" Foreground="{Binding Foreground}" FontSize="13" Padding="2" />
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}" />

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <oxy:PlotView Model="{Binding Model}" Background="Transparent" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
